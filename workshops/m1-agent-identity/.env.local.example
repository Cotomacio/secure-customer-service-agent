# M1 environment configuration — copy this file to .env.local and fill in values.
#
# .env.local is gitignored. Never commit it. Never check secrets in.
#
# For Stage 1 you only need GOOGLE_CLOUD_PROJECT and LOCATION.
# ORG_ID is recommended (cleaner SPIFFE URI) but optional — deploy.py falls back
# to a project-scoped form if no org is found.
#
# Stages 2/3/4 each add their own variables; uncomment when you reach them.

# --- Required for Stage 1 ---
export GOOGLE_CLOUD_PROJECT=
export LOCATION=us-central1

# --- Recommended ---
export ORG_ID=

# --- Stage 2: ServiceNow (2-legged OAuth) ---
# export SNOW_INSTANCE_URL=https://devXXXXX.service-now.com
# export SNOW_CLIENT_ID=
# export SNOW_CLIENT_SECRET=

# --- Stage 3: GitHub (3-legged OAuth) ---
# export GH_CLIENT_ID=
# export GH_CLIENT_SECRET=
# export GH_TEST_REPO=your-username/ada-bug-reports

# --- Stage 4: OpenWeather (API key) ---
# export OPENWEATHER_API_KEY=
